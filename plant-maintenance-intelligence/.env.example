# =============================================================
# .env.example — copy this to .env and fill in your values
# NEVER commit .env to git — it contains real credentials
# =============================================================

# ── Exasol Database ───────────────────────────────────────────
# Host: use 'localhost' when running on the EC2 instance itself
#       use the EC2 public DNS when connecting from your laptop
EXA_HOST=localhost
EXA_PORT=8563
EXA_USER=sys
EXA_PASSWORD=exasol

# ── Exasol Schema ─────────────────────────────────────────────
EXA_SCHEMA=PLANT_MAINTENANCE

# ── AWS / EC2 (used by deploy scripts, not the app itself) ────
# Update EC2_HOST every time you stop/start the instance
# Find it in: AWS Console → EC2 → Instances → Public IPv4 DNS
EC2_HOST=ec2-XX-XX-XX-XX.compute-1.amazonaws.com
EC2_USER=admin
PEM_FILE=d:\Machinary-problem\sheetal-server.pem
